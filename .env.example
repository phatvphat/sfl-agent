# Ollama embedding server
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# LanceDB storage path (relative to project root)
LANCEDB_PATH=./data/lancedb

# Sunflower Land frontend repo
SFL_REPO_URL=https://github.com/sunflower-land/sunflower-land.git
SFL_REPO_PATH=./data/sunflower-land

# Indexing
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
MAX_EMBED_CHARS=4000
INDEX_INCLUDE_GLOBS=src/**/*.ts,src/**/*.tsx,docs/**/*.md

# sfl.world APIs
SFL_PRICES_API_URL=https://sfl.world/api/v1/prices
SFL_EXCHANGE_API_URL=https://sfl.world/api/v1.1/exchange
SFL_NFTS_API_URL=https://sfl.world/api/v1/nfts

# Cursor SDK (web chat)
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# Web UI
# Local dev: 127.0.0.1 — deploy LAN: WEB_HOST=0.0.0.0
WEB_HOST=127.0.0.1
WEB_PORT=3847
WEB_WARM_AGENT=true
WEB_SHARED_AGENT=true
WEB_REUSE_AGENT=true
WEB_SCOPE_CHECK=true
# WEB_AGENT_ID=agent-xxx   # optional: pin agent id
# WEB_WARM_MCP_PING=true
# WEB_PERSIST_CHAT_CONTEXT=true
